{
  "name": "$board_name_long",
  "url": "$info_url",
  "vendor": "$vendor_name_long",
  "frameworks": ["arduino"],
  "build": {
    "core": "arduino",
    "extra_flags": $extra_flags_pio,
    "f_cpu": "$f_cpu",
    "mcu": "$chip_variant_lower",
    "variant": "$board_name"
  },
  "upload": {
    "maximum_ram_size": $ram_size,
    "maximum_size": $maximum_size,
    "protocol": "arduino",
    "require_upload_port": true,
    "speed": $upload_speed
  },
  "debug": {
    "simavr_target": "$chip_variant_lower"
  }
}
