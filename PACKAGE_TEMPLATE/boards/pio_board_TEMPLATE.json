{
  "name": "EnviroDIY Mayfly",
  "url": "http://envirodiy.org/forums/",
  "vendor": "EnviroDIY",
  "frameworks": ["arduino"],
  "build": {
    "core": "arduino",
    "extra_flags": $extra_flags_pio,
    "f_cpu": "$f_cpu",
    "mcu": "$chip_variant_lower",
    "variant": "$board_name"
  },
  "upload": {
    "protocol": "arduino",
    "require_upload_port": true,
    "maximum_ram_size": $ram_size,
    "maximum_size": $flash_size,
    "speed": $upload_speed
  },
  "debug": {
    "simavr_target": "$chip_variant_lower"
  }
}
